DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_DM_RECIPIENT_ID=
DISCORD_API_BASE_URL=https://discord.com/api/v10
DISCORD_GATEWAY_URL=wss://gateway.discord.gg/?v=10&encoding=json
DISCORD_GATEWAY_ENABLED=true
DISCORD_GATEWAY_INTENTS=37377

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_MARKET=US
SPOTIFY_REDIRECT_URI=http://127.0.0.1:4377/callback

LRCLIB_BASE_URL=https://lrclib.net

OWOTIFY_LOG_LEVEL=info
OWOTIFY_POLL_INTERVAL_MS=2000
OWOTIFY_LYRIC_LOOKAHEAD_MS=350
OWOTIFY_REWIND_RESET_THRESHOLD_MS=3000
OWOTIFY_MIN_MESSAGE_INTERVAL_MS=1100
OWOTIFY_MAX_LINES_PER_TICK=4
OWOTIFY_MAX_MESSAGE_LENGTH=1900
OWOTIFY_AUTO_START=false
OWOTIFY_OUTPUT_MODE=message
OWOTIFY_PRESENCE_STATUS=online
OWOTIFY_STATUS_TEMPLATE={line}
OWOTIFY_STATUS_IDLE_TEMPLATE=owotify idle
OWOTIFY_COMMANDS_ENABLED=true
OWOTIFY_COMMAND_PREFIX=owo
OWOTIFY_SEND_TRACK_HEADER=true
OWOTIFY_TRACK_HEADER_TEMPLATE=Now playing: {track} - {artist}
OWOTIFY_LYRIC_LINE_TEMPLATE={line}
OWOTIFY_NO_LYRICS_TEMPLATE=No synced lyrics found for {track} - {artist}.
OWOTIFY_PLAIN_LYRICS_MODE=off
OWOTIFY_PLAIN_LYRICS_TEMPLATE={plainLyrics}
OWOTIFY_SEND_NO_LYRICS_MESSAGE=true
